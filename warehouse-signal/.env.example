# Transcript Provider API Keys (set whichever you use)
FMP_API_KEY=
EARNINGSCALL_API_KEY=
FINNHUB_API_KEY=

# Which provider to use: fmp | earningscall | finnhub | mock
TRANSCRIPT_PROVIDER=mock

# Claude API for signal extraction
ANTHROPIC_API_KEY=

# Database
DATABASE_PATH=data/warehouse_signal.db

# Polling interval in seconds (for near-real-time ingestion)
POLL_INTERVAL_SECONDS=3600

# Signal extraction analyzer: claude | mock
ANALYZER=mock
EXTRACTION_VERSION=v1.0
EXTRACTION_CONCURRENCY=3
EXTRACTION_MAX_TOKENS=1024
